{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "cleanUrls": true,
    "regions": ["sin1"],
    "functions": {
        "api/nric/*.js": {
            "maxDuration": 30
        },
        "api/uen/*.js": {
            "maxDuration": 30
        },
        "api/carplate/*.js": {
            "maxDuration": 30
        }
    },
    "headers": [{
        "source": "/api/(.*)",
        "headers": [{
                "key": "Access-Control-Allow-Origin",
                "value": "*"
            },
            {
                "key": "Access-Control-Allow-Methods",
                "value": "GET, OPTIONS"
            },
            {
                "key": "Cache-Control",
                "value": "no-store"
            }
        ]
    }],
    "rewrites": [{
            "source": "/uen/generate",
            "destination": "/api/uen/generate"
        },
        {
            "source": "/uen/validate",
            "destination": "/api/uen/validate"
        },
        {
            "source": "/nric/generate",
            "destination": "/api/nric/generate"
        },
        {
            "source": "/nric/reconstruct",
            "destination": "/api/nric/reconstruct"
        },
        {
            "source": "/nric/validate",
            "destination": "/api/nric/validate"
        },
        {
            "source": "/carplate/generate",
            "destination": "/api/carplate/generate"
        },
        {
            "source": "/carplate/validate",
            "destination": "/api/carplate/validate"
        }
    ]
}
